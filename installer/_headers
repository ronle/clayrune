# Cloudflare Pages headers config — sets correct Content-Type for the
# installer files so browsers don't try to render them as HTML when a
# user pastes the URL into the address bar.

# install.sh / install.ps1 are served as attachments rather than text/plain.
# A user who opens https://clayrune.io/install.sh in a browser used to see
# the raw script body, and a tempting "select all + copy + paste into
# Terminal" path. zsh chokes on the `!` in `#!/usr/bin/env sh` (history
# expansion → `event not found: /usr/bin/env`) and the install never runs.
# Forcing a download means the only viable execution path is the canonical
# one-liner `curl -sSL https://clayrune.io/install.sh | sh`, which curl
# happily honors regardless of these headers.
/install.sh
  Content-Type: application/octet-stream
  Content-Disposition: attachment; filename="install.sh"
  Cache-Control: public, max-age=300

/install.ps1
  Content-Type: application/octet-stream
  Content-Disposition: attachment; filename="install.ps1"
  Cache-Control: public, max-age=300

/install-prompt.md
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=300

/start.sh
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=300

/start.command
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=300

/start.bat
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=300

# Double-click installer wrappers — served as octet-stream so they download
# instead of rendering as text in the browser. The `download` attribute on
# the anchor would suffice in modern browsers, but this is belt + suspenders.
/Clayrune-Setup.bat
  Content-Type: application/octet-stream
  Content-Disposition: attachment; filename="Clayrune-Setup.bat"
  Cache-Control: public, max-age=300

/Clayrune-Setup.command
  Content-Type: application/octet-stream
  Content-Disposition: attachment; filename="Clayrune-Setup.command"
  Cache-Control: public, max-age=300
