# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Node
node_modules/
package-lock.json

# Rust / Tauri build artifacts
src-tauri/target/

# User data (generated at runtime)
data/projects/*.json
data/projects/*_agent_log.json
# Per-project workspaces (data/projects/<id>/…) are USER DATA — never publish.
# Only top-level records + .gitkeep are tracked. (2026-06-09: engulfing-analyst
# content had slipped in tracked because the rule above only covers *.json — see
# the CHANGELOG security entry. This subdir rule closes that gap.)
data/projects/*/
data/uploads/*
!data/projects/.gitkeep
!data/uploads/.gitkeep
config.json
data/settings.json
data/grid_layout.json
data/schedules.json
data/restart_log.json
data/memory/
data/beacon/
/beacon/*.json
data/logs/
# Claydo helper sandbox: server materializes USER_GUIDE.md as CLAUDE.md
# under this dir on every /api/guide/* call so Claude auto-loads it as
# project context. Regenerated; not source. (data/playdo/ is the same dir
# under the pre-rename name — kept here so old installs that still have
# it don't dirty the working tree before _claydo_cwd's auto-rename runs.)
data/claydo/
data/playdo/
# Server writes install-launch.log into the install dir on Linux/macOS;
# install-prompt.md execution writes install.log when the old prompt-based
# install was used. Both are post-install runtime artifacts.
install-launch.log
install.log

# Build artifacts
build/
dist/
installer_output/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
nul

# Session / personal
.claude_session_context.md

# Logs
*.log

# Release artifacts
MissionControl-*.zip

# Design handoff archives (keep extracted docs, ignore zips)
docs/*.zip

# Runtime hivemind data
data/hiveminds/

# Local test fixtures
test_upload.txt

# Local Claude / IDE-agent state
.claude/

# Runtime remote-access state — names are scoped to user's CF Access nonces
data/session_labels.json

# Runtime web-push state — push_vapid.json contains the PRIVATE VAPID key,
# push_subscriptions.json contains per-device endpoints + auth secrets,
# system_status.json is restart/heartbeat state. All regenerated at runtime.
data/push_vapid.json
data/push_subscriptions.json
data/notifications.json
data/system_status.json

# First-boot onboarding-seed marker (guide_routes.seed_onboarding_on_startup).
# Lives in data/ (NOT data/projects/ — load_projects() must never see it).
data/onboarding_seeded.flag

# SQLite state DB (docs/SQLITE_MIGRATION_SPEC.md) + its WAL/SHM sidecars.
# Runtime state, rebuilt by backfill from the JSON during migration; never commit.
data/mc.db
data/mc.db-wal
data/mc.db-shm

# Firebase Admin SDK service-account key — used by server to send FCM pushes
# to the native Android app. Contains a private RSA key; never commit.
data/firebase_admin.json

# Mobile pairing — CF Access service-token credentials used to provision the
# Clayrune Android shell via QR code. Contains the secret in plaintext (must
# be readable to render the QR each time the user views the pairing page).
data/mobile_pairing.json

# Local network passcode — gate for direct LAN access to the dashboard.
# Contains the passcode hash + salt and the cookie-signing secret; never commit.
data/local_auth.json

# Monthly maintenance audit reports — runtime output of the read-only
# audit (docs/MAINTENANCE_AUDIT_PROMPT.md). Reviewed by Ron, not
# committed. Gitignoring this is what lets the audit satisfy its own
# "git status byte-identical" read-only invariant.
data/maintenance_reports/

# Night-shift maintenance reports — runtime output of the night-review
# schedule (tools/night-review/). Reviewed by Ron + emailed; not committed.
# Same posture as data/maintenance_reports/. (The skips log is a *.log and is
# already covered above.)
docs/night-review-*.md

# Weekly GCP cost-review reports — runtime output of the gcp-cost-review
# schedule (tools/gcp-cost-review/). Emailed to Ron; not committed. (Skips log
# is a *.log, already covered above.)
docs/gcp-cost-review-*.md

# Build artifacts served from /downloads (Android APK, etc.) — produced by
# the mobile build pipeline, not source.
static/downloads/*.apk
static/downloads/*.aab

# memsearch (Zilliz) — Claude Code persistent-memory plugin. Per-project
# storage dir holds daily session-summary markdown, the Milvus Lite vector
# index, and a watch-process PID file. Markdown is regenerable (claude-mem
# rebuilds from session); vector index is a derived cache. Nothing to commit.
.memsearch/

# Bundled third-party binaries (cloudflared, future Rust mc-tunnel artifacts)
# These are fetched at build time, not committed. README + LICENSE stay.
mc_tunnel/bin/cloudflared
mc_tunnel/bin/cloudflared.exe
mc_tunnel/bin/cloudflared-darwin-amd64
mc_tunnel/bin/cloudflared-darwin-arm64
mc_tunnel/bin/cloudflared-linux-amd64
mc_tunnel/bin/cloudflared-linux-arm64
mc_tunnel/bin/*/cloudflared

